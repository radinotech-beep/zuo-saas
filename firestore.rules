rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsCafe(cafeId) {
      return signedIn()
        && cafeId is string
        && exists(/databases/$(database)/documents/cafes/$(cafeId))
        && get(/databases/$(database)/documents/cafes/$(cafeId)).data.ownerUid == request.auth.uid;
    }

    function cafeCreateAllowed() {
      return signedIn()
        && request.resource.data.ownerUid == request.auth.uid;
    }

    function cafeReadAllowed() {
      return signedIn()
        && resource.data.ownerUid == request.auth.uid;
    }

    function cafeUpdateAllowed() {
      return cafeReadAllowed()
        && request.resource.data.ownerUid == resource.data.ownerUid;
    }

    function childCreateAllowed() {
      return ownsCafe(request.resource.data.cafeId);
    }

    function childReadAllowed() {
      return ownsCafe(resource.data.cafeId);
    }

    function childUpdateAllowed() {
      return childReadAllowed()
        && request.resource.data.cafeId == resource.data.cafeId;
    }

    function publicCafeChildReadAllowed() {
      return resource.data.cafeId is string;
    }

    function publicCafeChildCreateAllowed() {
      return request.resource.data.cafeId is string;
    }

    function publicCafeChildUpdateAllowed() {
      return publicCafeChildReadAllowed()
        && request.resource.data.cafeId == resource.data.cafeId;
    }

    match /cafes/{cafeId} {
      allow create: if cafeCreateAllowed();
      allow get: if true;
      allow list: if cafeReadAllowed();
      allow update: if cafeUpdateAllowed();
      allow delete: if cafeReadAllowed();
    }

    match /employees/{docId} {
      allow create: if childCreateAllowed();
      allow read: if childReadAllowed() || publicCafeChildReadAllowed();
      allow update: if childUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /workHours/{docId} {
      allow create: if childCreateAllowed() || publicCafeChildCreateAllowed();
      allow read: if childReadAllowed() || publicCafeChildReadAllowed();
      allow update: if childUpdateAllowed() || publicCafeChildUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /workConfirm/{docId} {
      allow create: if childCreateAllowed() || publicCafeChildCreateAllowed();
      allow read: if childReadAllowed() || publicCafeChildReadAllowed();
      allow update: if childUpdateAllowed() || publicCafeChildUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /notices/{docId} {
      allow create: if childCreateAllowed() || publicCafeChildCreateAllowed();
      allow read: if childReadAllowed() || publicCafeChildReadAllowed();
      allow update: if childUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /healthCerts/{docId} {
      allow create: if childCreateAllowed() || publicCafeChildCreateAllowed();
      allow read: if childReadAllowed() || publicCafeChildReadAllowed();
      allow update: if childUpdateAllowed() || publicCafeChildUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /supplies/{docId} {
      allow create: if childCreateAllowed();
      allow read: if childReadAllowed() || publicCafeChildReadAllowed();
      allow update: if childUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /subs/{docId} {
      allow create: if childCreateAllowed() || publicCafeChildCreateAllowed();
      allow read: if childReadAllowed() || publicCafeChildReadAllowed();
      allow update: if childUpdateAllowed() || publicCafeChildUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /regularSchedules/{docId} {
      allow create: if childCreateAllowed();
      allow read: if childReadAllowed() || publicCafeChildReadAllowed();
      allow update: if childUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /payslips/{docId} {
      allow create: if childCreateAllowed();
      allow read: if childReadAllowed();
      allow update: if childUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /profits/{docId} {
      allow create: if childCreateAllowed();
      allow read: if childReadAllowed();
      allow update: if childUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /profitFixed/{docId} {
      allow create: if childCreateAllowed();
      allow read: if childReadAllowed();
      allow update: if childUpdateAllowed();
      allow delete: if childReadAllowed();
    }
  }
}
