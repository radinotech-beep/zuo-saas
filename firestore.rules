rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return signedIn()
        && request.auth.token.email == "radinotech@gmail.com";
    }

    function activeApprovedUser() {
      return isSuperAdmin()
        || (
          signedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == "active"
        );
    }

    function ownsCafe(cafeId) {
      return activeApprovedUser()
        && cafeId is string
        && exists(/databases/$(database)/documents/cafes/$(cafeId))
        && get(/databases/$(database)/documents/cafes/$(cafeId)).data.ownerUid == request.auth.uid;
    }

    function cafeCreateAllowed() {
      return activeApprovedUser()
        && request.resource.data.ownerUid == request.auth.uid;
    }

    function cafeReadAllowed() {
      return activeApprovedUser()
        && resource.data.ownerUid == request.auth.uid;
    }

    function cafeUpdateAllowed() {
      return cafeReadAllowed()
        && request.resource.data.ownerUid == resource.data.ownerUid;
    }

    function childCreateAllowed() {
      return ownsCafe(request.resource.data.cafeId);
    }

    function childReadAllowed() {
      return ownsCafe(resource.data.cafeId);
    }

    function childUpdateAllowed() {
      return childReadAllowed()
        && request.resource.data.cafeId == resource.data.cafeId;
    }

    function publicCafeChildReadAllowed() {
      return !signedIn() && resource.data.cafeId is string;
    }

    function publicCafeChildCreateAllowed() {
      return !signedIn() && request.resource.data.cafeId is string;
    }

    function publicCafeChildUpdateAllowed() {
      return publicCafeChildReadAllowed()
        && request.resource.data.cafeId == resource.data.cafeId;
    }

    match /users/{uid} {
      allow create: if signedIn()
        && uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && (
          (
            request.auth.token.email != "radinotech@gmail.com"
            && request.resource.data.approved == false
            && request.resource.data.status == "active"
          )
          ||
          (
            request.auth.token.email == "radinotech@gmail.com"
            && request.resource.data.approved == true
            && request.resource.data.status == "active"
          )
        );
      allow get: if signedIn() && (uid == request.auth.uid || isSuperAdmin());
      allow list: if isSuperAdmin();
      allow update: if (
          isSuperAdmin()
          && (
            uid != request.auth.uid
            || (
              request.resource.data.status != "suspended"
              && request.resource.data.status != "withdrawn"
              && request.resource.data.approved == true
            )
          )
        )
        || (
          signedIn()
          && uid == request.auth.uid
          && request.resource.data.email == request.auth.token.email
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["email", "approved", "status", "updatedAt"])
          && request.resource.data.approved == false
          && request.resource.data.status == "active"
        );
      allow delete: if false;
    }

    match /cafes/{cafeId} {
      allow create: if cafeCreateAllowed();
      allow get: if cafeReadAllowed() || isSuperAdmin() || !signedIn();
      allow list: if cafeReadAllowed() || isSuperAdmin();
      allow update: if cafeUpdateAllowed();
      allow delete: if cafeReadAllowed();
    }

    match /employees/{docId} {
      allow create: if childCreateAllowed();
      allow read: if childReadAllowed() || publicCafeChildReadAllowed();
      allow update: if childUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /workHours/{docId} {
      allow create: if childCreateAllowed() || publicCafeChildCreateAllowed();
      allow read: if childReadAllowed() || publicCafeChildReadAllowed();
      allow update: if childUpdateAllowed() || publicCafeChildUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /workConfirm/{docId} {
      allow create: if childCreateAllowed() || publicCafeChildCreateAllowed();
      allow read: if childReadAllowed() || publicCafeChildReadAllowed();
      allow update: if childUpdateAllowed() || publicCafeChildUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /notices/{docId} {
      allow create: if childCreateAllowed() || publicCafeChildCreateAllowed();
      allow read: if childReadAllowed() || publicCafeChildReadAllowed();
      allow update: if childUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /healthCerts/{docId} {
      allow create: if childCreateAllowed() || publicCafeChildCreateAllowed();
      allow read: if childReadAllowed() || publicCafeChildReadAllowed();
      allow update: if childUpdateAllowed() || publicCafeChildUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /supplies/{docId} {
      allow create: if childCreateAllowed();
      allow read: if childReadAllowed() || publicCafeChildReadAllowed();
      allow update: if childUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /subs/{docId} {
      allow create: if childCreateAllowed() || publicCafeChildCreateAllowed();
      allow read: if childReadAllowed() || publicCafeChildReadAllowed();
      allow update: if childUpdateAllowed() || publicCafeChildUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /regularSchedules/{docId} {
      allow create: if childCreateAllowed();
      allow read: if childReadAllowed() || publicCafeChildReadAllowed();
      allow update: if childUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /payslips/{docId} {
      allow create: if childCreateAllowed();
      allow read: if childReadAllowed();
      allow update: if childUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /profits/{docId} {
      allow create: if childCreateAllowed();
      allow read: if childReadAllowed();
      allow update: if childUpdateAllowed();
      allow delete: if childReadAllowed();
    }

    match /profitFixed/{docId} {
      allow create: if childCreateAllowed();
      allow read: if childReadAllowed();
      allow update: if childUpdateAllowed();
      allow delete: if childReadAllowed();
    }
  }
}
